<Window x:Class="PakToolGUI.RecoilEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Recoil Curve Editor" Height="720" Width="1000"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResizeWithGrip"
        MinHeight="500" MinWidth="800"
        Background="#1a1b26">

    <Window.Resources>
        <SolidColorBrush x:Key="BgPrimary" Color="#1a1b26"/>
        <SolidColorBrush x:Key="BgSecondary" Color="#24283b"/>
        <SolidColorBrush x:Key="BgTertiary" Color="#2f3348"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#c0caf5"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#a9b1d6"/>
        <SolidColorBrush x:Key="TextMuted" Color="#565f89"/>
        <SolidColorBrush x:Key="Accent" Color="#7aa2f7"/>
        <SolidColorBrush x:Key="Success" Color="#9ece6a"/>
        <SolidColorBrush x:Key="Warning" Color="#e0af68"/>
        <SolidColorBrush x:Key="Error" Color="#f7768e"/>
        <SolidColorBrush x:Key="BorderColor" Color="#3b4261"/>

        <Style x:Key="DarkButton" TargetType="Button">
            <Setter Property="Background" Value="#2f3348"/>
            <Setter Property="Foreground" Value="#c0caf5"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderBrush" Value="#3b4261"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="14,6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#363b54"/>
                    <Setter Property="BorderBrush" Value="#7aa2f7"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.5"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="PrimaryBtn" TargetType="Button" BasedOn="{StaticResource DarkButton}">
            <Setter Property="Background" Value="#3d59a1"/>
            <Setter Property="Foreground" Value="#ffffff"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="SuccessBtn" TargetType="Button" BasedOn="{StaticResource DarkButton}">
            <Setter Property="Background" Value="#2d5a3d"/>
            <Setter Property="Foreground" Value="#9ece6a"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#24283b" Padding="16,12"
                BorderBrush="#3b4261" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <TextBlock Text="&#x1F3AF;" FontSize="20" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <StackPanel>
                        <TextBlock x:Name="TxtTitle" Text="Recoil Curve Editor" FontSize="16" FontWeight="Bold"
                                   Foreground="#c0caf5"/>
                        <TextBlock x:Name="TxtFilePath" Text="" FontSize="10"
                                   Foreground="#565f89" TextTrimming="CharacterEllipsis" MaxWidth="500"/>
                    </StackPanel>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button x:Name="BtnOpen" Content="&#x1F4C2; Open File" Style="{StaticResource DarkButton}"
                            Width="110" Margin="0,0,8,0" Click="BtnOpen_Click"/>
                    <Button x:Name="BtnBatchLoad" Content="&#x1F4E6; Load All Recoils" Style="{StaticResource DarkButton}"
                            Width="140" Margin="0,0,8,0" Click="BtnBatchLoad_Click"
                            ToolTip="Load all 25 recoil curves from the unpacked PAK"/>
                    <Button x:Name="BtnApply" Content="&#x2714; Apply" Style="{StaticResource PrimaryBtn}"
                            Width="90" Margin="0,0,8,0" IsEnabled="False" Click="BtnApply_Click"/>
                    <Button x:Name="BtnSave" Content="&#x1F4BE; Save" Style="{StaticResource SuccessBtn}"
                            Width="90" IsEnabled="False" Click="BtnSave_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Content -->
        <Grid Grid.Row="1" Margin="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left Panel: Weapon List -->
            <Border Grid.Column="0" Background="#24283b" CornerRadius="6"
                    BorderBrush="#3b4261" BorderThickness="1" Margin="0,0,8,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="Weapons" FontSize="13" FontWeight="Bold"
                               Foreground="#7aa2f7" Margin="12,10,0,6"/>
                    <ListBox x:Name="WeaponList" Grid.Row="1"
                             Background="Transparent" BorderThickness="0"
                             Foreground="#c0caf5" FontSize="12"
                             SelectionChanged="WeaponList_SelectionChanged">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="12,6"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border Background="{TemplateBinding Background}"
                                                    Padding="{TemplateBinding Padding}"
                                                    CornerRadius="4" Margin="4,1">
                                                <ContentPresenter/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="#3d59a1"/>
                                    </Trigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#2f3348"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </ListBox.ItemContainerStyle>
                    </ListBox>
                </Grid>
            </Border>

            <!-- Right Panel: Curve Tabs + Keyframe Grid -->
            <Border Grid.Column="1" Background="#24283b" CornerRadius="6"
                    BorderBrush="#3b4261" BorderThickness="1">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Curve Tabs -->
                    <TabControl x:Name="CurveTabs" Grid.Row="0"
                                Background="Transparent" BorderThickness="0,0,0,1"
                                BorderBrush="#3b4261" SelectionChanged="CurveTabs_SelectionChanged">
                        <TabControl.Resources>
                            <Style TargetType="TabItem">
                                <Setter Property="Foreground" Value="#565f89"/>
                                <Setter Property="FontSize" Value="12"/>
                                <Setter Property="Padding" Value="16,6"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="TabItem">
                                            <Border Background="{TemplateBinding Background}"
                                                    Padding="{TemplateBinding Padding}"
                                                    BorderBrush="Transparent" BorderThickness="0,0,0,2">
                                                <ContentPresenter/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter Property="Foreground" Value="#7aa2f7"/>
                                                    <Setter Property="BorderBrush" Value="#7aa2f7"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </TabControl.Resources>
                    </TabControl>

                    <!-- Keyframe DataGrid -->
                    <DataGrid x:Name="KeyframeGrid" Grid.Row="1"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              CanUserResizeColumns="True"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal"
                              HorizontalGridLinesBrush="#2f3348"
                              SelectionMode="Single"
                              FontSize="12" FontFamily="Consolas"
                              RowHeight="28"
                              Background="Transparent"
                              RowBackground="Transparent"
                              AlternatingRowBackground="#1e2030"
                              CellEditEnding="KeyframeGrid_CellEditEnding">
                        <DataGrid.Resources>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="#1a1b26"/>
                                <Setter Property="Foreground" Value="#7aa2f7"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                                <Setter Property="FontSize" Value="11"/>
                                <Setter Property="BorderBrush" Value="#3b4261"/>
                                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                <Setter Property="Padding" Value="10,6"/>
                            </Style>
                            <Style TargetType="DataGridCell">
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Padding" Value="10,3"/>
                                <Setter Property="Foreground" Value="#c0caf5"/>
                                <Setter Property="Background" Value="Transparent"/>
                            </Style>
                        </DataGrid.Resources>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="#" Binding="{Binding Index}" Width="40" IsReadOnly="True">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#565f89"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTemplateColumn Header="Time" Width="130">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBox Text="{Binding Time, UpdateSourceTrigger=PropertyChanged, StringFormat={}{0:F6}}"
                                                 Background="#2f3348" Foreground="#c0caf5"
                                                 BorderBrush="#3b4261" BorderThickness="1"
                                                 Padding="6,2" FontFamily="Consolas" FontSize="11"
                                                 CaretBrush="#c0caf5"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="Value" Width="130">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBox Text="{Binding Value, UpdateSourceTrigger=PropertyChanged, StringFormat={}{0:F6}}"
                                                 Background="#2f3348" Foreground="#e0af68"
                                                 BorderBrush="#3b4261" BorderThickness="1"
                                                 Padding="6,2" FontFamily="Consolas" FontSize="11"
                                                 CaretBrush="#c0caf5"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="ArriveTangent" Width="140">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBox Text="{Binding ArriveTangent, UpdateSourceTrigger=PropertyChanged, StringFormat={}{0:F6}}"
                                                 Background="#2f3348" Foreground="#a9b1d6"
                                                 BorderBrush="#3b4261" BorderThickness="1"
                                                 Padding="6,2" FontFamily="Consolas" FontSize="11"
                                                 CaretBrush="#c0caf5"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="LeaveTangent" Width="140">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBox Text="{Binding LeaveTangent, UpdateSourceTrigger=PropertyChanged, StringFormat={}{0:F6}}"
                                                 Background="#2f3348" Foreground="#a9b1d6"
                                                 BorderBrush="#3b4261" BorderThickness="1"
                                                 Padding="6,2" FontFamily="Consolas" FontSize="11"
                                                 CaretBrush="#c0caf5"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="InterpMode" Binding="{Binding InterpMode}" Width="110" IsReadOnly="True">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#565f89"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="TangentMode" Binding="{Binding TangentMode}" Width="110" IsReadOnly="True">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#565f89"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </Grid>

        <!-- Status Bar -->
        <Border Grid.Row="2" Background="#24283b" Padding="14,5"
                BorderBrush="#3b4261" BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <TextBlock x:Name="TxtStatus" Text="Ready - Open a recoil .uasset or click Load All"
                               FontSize="11" Foreground="#565f89"/>
                </StackPanel>
                <TextBlock Grid.Column="1" x:Name="TxtModCount" Text="" FontSize="11"
                           Foreground="#e0af68"/>
            </Grid>
        </Border>
    </Grid>
</Window>
