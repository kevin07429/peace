<Application x:Class="PakToolGUI.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <!-- Colors -->
        <SolidColorBrush x:Key="BgPrimary" Color="#111417"/>
        <SolidColorBrush x:Key="BgSecondary" Color="#1B2025"/>
        <SolidColorBrush x:Key="BgTertiary" Color="#151A1F"/>
        <SolidColorBrush x:Key="BgInput" Color="#242B31"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#EDF2F7"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#C5CFD8"/>
        <SolidColorBrush x:Key="TextMuted" Color="#83909C"/>
        <SolidColorBrush x:Key="Accent" Color="#1FD18B"/>
        <SolidColorBrush x:Key="AccentHover" Color="#36E2A0"/>
        <SolidColorBrush x:Key="Success" Color="#76E0A6"/>
        <SolidColorBrush x:Key="Warning" Color="#F0C36A"/>
        <SolidColorBrush x:Key="Error" Color="#FF7185"/>
        <SolidColorBrush x:Key="Info" Color="#82B7FF"/>
        <SolidColorBrush x:Key="BorderColor" Color="#34404A"/>

        <!-- Primary Button -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#00C878"/>
            <Setter Property="Foreground" Value="#07110C"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="MinHeight" Value="38"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="5" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#20E090"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#3A443F"/>
                    <Setter Property="Foreground" Value="#7B8780"/>
                    <Setter Property="Cursor" Value="Arrow"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Secondary Button -->
        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Background" Value="#282D2A"/>
            <Setter Property="Foreground" Value="#EDF2F7"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderBrush" Value="#3A443F"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="MinHeight" Value="36"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2B343B"/>
                    <Setter Property="BorderBrush" Value="#00C878"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#202422"/>
                    <Setter Property="Foreground" Value="#7B8780"/>
                    <Setter Property="BorderBrush" Value="#303832"/>
                    <Setter Property="Cursor" Value="Arrow"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Toggle -->
        <Style x:Key="ToggleCheckBox" TargetType="CheckBox">
            <Setter Property="Foreground" Value="#C2CCC5"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <!-- TextBox -->
        <Style TargetType="TextBox">
            <Setter Property="Foreground" Value="#EDF2F7"/>
            <Setter Property="Background" Value="#242B31"/>
            <Setter Property="BorderBrush" Value="#34404A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="CaretBrush" Value="#EDF2F7"/>
            <Setter Property="MinHeight" Value="34"/>
        </Style>

        <!-- ProgressBar -->
        <Style TargetType="ProgressBar">
            <Setter Property="Height" Value="8"/>
            <Setter Property="Background" Value="#282D2A"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="#00C878"/>
        </Style>
        <!-- Small Button -->
        <Style x:Key="SmallBtn" TargetType="Button">
            <Setter Property="Background" Value="#282D2A"/>
            <Setter Property="Foreground" Value="#EDF2F7"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderBrush" Value="#3A443F"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2B343B"/>
                    <Setter Property="BorderBrush" Value="#00C878"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <!-- Hex Input -->
        <Style x:Key="HexInput" TargetType="TextBox">
            <Setter Property="Foreground" Value="#EDF2F7"/>
            <Setter Property="Background" Value="#242B31"/>
            <Setter Property="BorderBrush" Value="#34404A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="CaretBrush" Value="#EDF2F7"/>
            <Setter Property="MinHeight" Value="34"/>
        </Style>

        <!-- Field Label -->
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#C2CCC5"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- Section title -->
        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#EDF2F7"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <!-- Card title -->
        <Style x:Key="CardTitle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#EDF2F7"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <!-- Muted copy -->
        <Style x:Key="MutedCopy" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#83909C"/>
            <Setter Property="FontSize" Value="10.5"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>
    </Application.Resources>
</Application>
